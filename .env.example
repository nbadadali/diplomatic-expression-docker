# =============================================================================
# .env.example — copy to .env before running docker compose up
#   cp .env.example .env
#
# Secrets marked "AUTO-GENERATED" are filled in by deploy.sh automatically.
# Do NOT change placeholder values — deploy.sh detects and replaces them.
# =============================================================================

N8N_IMAGE_TAG=2.28.0

# AUTO-GENERATED by deploy.sh — do not set manually.
N8N_ENCRYPTION_KEY=replace-with-a-long-random-string
N8N_JWT_SECRET=replace-with-a-long-random-string

N8N_EDITOR_BASE_URL=http://localhost:5678
WEBHOOK_URL=http://localhost:5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_PORT=5678
N8N_LISTEN_ADDRESS=0.0.0.0
N8N_SECURE_COOKIE=false
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
N8N_BLOCK_ENV_ACCESS=true
N8N_BLOCK_ENV_ACCESS_IN_NODE=true
N8N_BLOCK_ENV_VARS_FROM_EXPRESSIONS=true
EXECUTIONS_MODE=queue
OFFLOAD_MANUAL_EXECUTIONS_TO_WORKERS=true
GENERIC_TIMEZONE=Asia/Dubai

DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
# AUTO-GENERATED by deploy.sh — do not set manually.
DB_POSTGRESDB_PASSWORD=change-me

# Leave blank for no auth. deploy.sh passes REDIS_PASSWORD here if set.
REDIS_PASSWORD=

PGVECTOR_DB=vector
PGVECTOR_USER=vector
# AUTO-GENERATED by deploy.sh — do not set manually.
PGVECTOR_PASSWORD=change-me-too
PGVECTOR_PORT=5432

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
GOOGLE_OAUTH_TOKEN_URL=
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=
PINECONE_NAMESPACE=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=

# AUTO-GENERATED by deploy.sh — do not set manually.
MCP_AUTH_TOKEN=choose-a-secret-token

# Set AFTER first n8n login: Settings -> API -> Create API Key.
# Then: ./deploy.sh --only env_file  and restart workers.
N8N_API_KEY=

N8N_BASE_URL=http://n8n:5678
