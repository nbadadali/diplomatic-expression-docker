# Copy this to `.env` before running `docker compose up -d --build`

# -----------------------------------------------------------------------------
# Core n8n
# -----------------------------------------------------------------------------
# Pick a specific image tag if you do not want latest.
N8N_IMAGE_TAG=latest

# Fresh secret for this new setup. Do not reuse the Railway one.
N8N_ENCRYPTION_KEY=replace-with-a-long-random-string

# Used by n8n internally for session/auth signing.
N8N_JWT_SECRET=replace-with-a-long-random-string

# Local URLs for the editor and webhook callbacks.
N8N_EDITOR_BASE_URL=http://localhost:5678
WEBHOOK_URL=http://localhost:5678

# n8n runtime settings.
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_PORT=5678
N8N_LISTEN_ADDRESS=0.0.0.0
N8N_SECURE_COOKIE=false
N8N_RUNNERS_ENABLED=true
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
N8N_BLOCK_ENV_ACCESS=true
N8N_BLOCK_ENV_ACCESS_IN_NODE=true
N8N_BLOCK_ENV_VARS_FROM_EXPRESSIONS=true
EXECUTIONS_MODE=queue
GENERIC_TIMEZONE=Asia/Dubai

# -----------------------------------------------------------------------------
# n8n Postgres
# -----------------------------------------------------------------------------
# Database that n8n will use.
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=change-me

# -----------------------------------------------------------------------------
# Redis queue
# -----------------------------------------------------------------------------
# Leave blank unless you want to protect Redis with a password.
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# pgvector service
# -----------------------------------------------------------------------------
PGVECTOR_DB=vector
PGVECTOR_USER=vector
PGVECTOR_PASSWORD=change-me-too
PGVECTOR_PORT=5432

# -----------------------------------------------------------------------------
# Optional external integrations used by your Railway setup
# -----------------------------------------------------------------------------
# Leave empty unless your workflows depend on them.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
GOOGLE_OAUTH_TOKEN_URL=
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=
PINECONE_NAMESPACE=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=

# -----------------------------------------------------------------------------
# MCP server
# -----------------------------------------------------------------------------
# Shared auth token between the MCP server and n8n.
MCP_AUTH_TOKEN=choose-a-secret-token

# n8n API key used by the MCP server.
N8N_API_KEY=replace-with-an-n8n-api-key

# Internal Docker network URL for n8n.
N8N_BASE_URL=http://n8n:5678
